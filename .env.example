# Public domain name pointing to this server (used by Caddy for TLS certificate)
# Must be a real domain with an A record pointing to your Hetzner server IP
DOMAIN=api.yourdomain.com

# PostgreSQL superuser name used when initialising the database container
POSTGRES_USER=app

# PostgreSQL password for the above user — change before any shared deployment
POSTGRES_PASSWORD=changeme

# Name of the PostgreSQL database created on first boot
POSTGRES_DB=hydra

# Password required by Redis; passed to redis-server --requirepass and to the StackExchange.Redis connection string
REDIS_PASSWORD=changeme

# HS256 signing secret for JWT tokens — must be at least 32 characters
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Google Places API key used server-side to resolve venue photo URLs; never sent to the frontend
GOOGLE_PLACES_API_KEY=

# Resend API key for transactional emails (verification OTPs, password reset)
RESEND_API_KEY=re_your_api_key_here

# Google OAuth client ID for social login
GOOGLEAUTH__CLIENTID=
