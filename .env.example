# Public domain name pointing to this server (used by Caddy for TLS certificate)
# Must be a real domain with an A record pointing to your Hetzner server IP
DOMAIN=api.yourdomain.com

# PostgreSQL superuser name used when initialising the database container
POSTGRES_USER=app

# PostgreSQL password for the above user — change before any shared deployment
POSTGRES_PASSWORD=changeme

# Name of the PostgreSQL database created on first boot
POSTGRES_DB=hydra

# Password required by Redis; passed to redis-server --requirepass and to the StackExchange.Redis connection string
REDIS_PASSWORD=changeme

# HS256 signing secret for JWT tokens — must be at least 32 characters
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Resend API key for transactional emails (verification OTPs, password reset)
RESEND_API_KEY=re_your_api_key_here

# Google OAuth client ID for social login
GOOGLEAUTH__CLIENTID=

# Cloudflare R2 credentials — create an R2 bucket in the Cloudflare dashboard,
# then generate an API token with Object Read & Write permissions.
CLOUDFLARER2__ACCOUNTID=your_cloudflare_account_id
CLOUDFLARER2__ACCESSKEYID=your_r2_access_key_id
CLOUDFLARER2__SECRETACCESSKEY=your_r2_secret_access_key
CLOUDFLARER2__BUCKETNAME=hydra-photos
# Public base URL for the bucket (enable R2 public access or use a custom domain)
CLOUDFLARER2__PUBLICDOMAIN=https://pub-xxxx.r2.dev

# CORS allowed origins — comma-separated list of browser origins allowed to call
# the API. Put your Vercel admin panel URL here (and its custom domain if any).
# If unset, the API falls back to localhost origins (local dev only).
CORS_ALLOWED_ORIGINS=https://your-admin.vercel.app,https://admin.yourdomain.com

# Initial SuperAdmin account, created on first startup if it does not already exist.
# This is the only account seeded in Production — use it to log in and set everything up.
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=change-this-to-a-strong-password
# "Google" if SUPERADMIN_EMAIL is a real Gmail you'll log in with via "Continue
# with Google" (the password above is then unused, just a DB placeholder).
# "Email" (or unset) for a normal password login instead. Kept in sync on every
# restart, so changing this and redeploying fixes an existing SuperAdmin too.
SUPERADMIN_AUTHPROVIDER=Google
